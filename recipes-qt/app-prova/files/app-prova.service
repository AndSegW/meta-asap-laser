[Unit]
Description=ASAP HMI Qt Application
After=weston.service
Requires=weston.service

[Service]
Type=simple
User=weston
Group=weston
ExecStart=/bin/sh -c 'export XDG_RUNTIME_DIR=/run/user/$(id -u); export WAYLAND_DISPLAY=wayland-1; sleep 3; exec /usr/bin/appProva -platform wayland'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
